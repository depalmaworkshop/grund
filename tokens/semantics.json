{
  "$description": "Default-theme semantic tokens. Slots are the structure the Share/options-popover Pattern + Button need. Colours are CANDIDATE values harvested from the live sites (under review, may change); the convergent structural values (radius/space/type/shadow) are SET. Dark-scheme overrides live in semantics.dark.json.",
  "color": {
    "popover": {
      "surface":       { "$value": "{color.paper}", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
      "border":        { "$value": "color-mix(in srgb, {color.ink} 12%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
      "text":          { "$value": "{color.ink}", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
      "text-muted":    { "$value": "color-mix(in srgb, {color.ink} 62%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
      "item-hover-bg": { "$value": "color-mix(in srgb, {color.ink} 6%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } }
    },
    "focus-ring":      { "$value": "#3b82f6", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
    "button": {
      "primary": {
        "bg":       { "$value": "{color.ink}", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
        "text":     { "$value": "{color.paper}", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
        "bg-hover": { "$value": "color-mix(in srgb, {color.ink} 88%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } }
      },
      "ghost": {
        "text":     { "$value": "{color.ink}", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
        "border":   { "$value": "color-mix(in srgb, {color.ink} 18%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } },
        "bg-hover": { "$value": "color-mix(in srgb, {color.ink} 6%, transparent)", "$type": "color", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } }
      }
    }
  },
  "space": {
    "popover": {
      "padding": { "$value": "12px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "item-x":  { "$value": "12px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "item-y":  { "$value": "8px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "gap":     { "$value": "4px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } }
    },
    "button": {
      "padding-x": { "$value": "16px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "padding-y": { "$value": "8px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "gap":       { "$value": "8px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } }
    }
  },
  "radius": {
    "popover":      { "$value": "8px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
    "popover-item": { "$value": "6px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
    "button":       { "$value": "6px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } }
  },
  "font": {
    "popover": {
      "size":   { "$value": "14px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "weight": { "$value": "500", "$type": "fontWeight", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } }
    },
    "button": {
      "size":   { "$value": "14px", "$type": "dimension", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } } },
      "weight": { "$value": "500", "$type": "fontWeight", "$extensions": { "com.grund.status": { "token": "confirmed", "value": "candidate" } } }
    }
  },
  "shadow": {
    "popover": {
      "$value": "0 10px 15px -3px rgb(35 31 32 / 0.10), 0 4px 6px -4px rgb(35 31 32 / 0.10)",
      "$type": "shadow",
      "$extensions": { "com.grund.status": { "token": "confirmed", "value": "set" } }
    }
  }
}
